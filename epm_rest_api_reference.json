  "job_types": [
    {
      "type": "RULES",
      "description": "Execute a business rule"
    },
    {
      "type": "RULESET",
      "description": "Execute a ruleset (set of business rules)"
    },
    {
      "type": "PLAN_TYPE_MAP",
      "description": "Copy data between plan types (BSO to ASO)"
    },
    {
      "type": "IMPORT_DATA",
      "description": "Import data from a file into the application",
      "parameters": {
        "importFileName": "Name of the import file",
        "sourceType": "Source type (optional, e.g., 'Essbase')",
        "cube": "Cube/plan type name"
      }
    },
    {
      "type": "EXPORT_DATA",
